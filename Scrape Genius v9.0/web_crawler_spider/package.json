{
  "name": "web-crawler-spider",
  "version": "9.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev:backend\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "cd backend && npm install",
    "install-enhanced": "npm install fingerprint-generator fingerprint-injector ghost-cursor linkedin-profile-scraper",
    "setup": "npm install && npm run install-enhanced && cd backend && npm install && npx playwright install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@mui/x-data-grid": "^9.9.0",
    "@prisma/client": "^4.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.14",
    "axios": "^1.18.1",
    "bcrypt": "^5.0.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.0.3",
    "encoding": "^0.1.13",
    "eslint": "^8.39.0",
    "eslint-config-next": "13.4.2",
    "jsonwebtoken": "^9.0.0",
    "libphonenumber-js": "^1.13.8",
    "mammoth": "^1.12.0",
    "mysql2": "^3.2.0",
    "next": "^13.4.2",
    "papaparse": "^5.5.4",
    "playwright": "^1.61.1",
    "postcss": "^8.4.23",
    "preline": "^1.9.0",
    "puppeteer": "^22.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-clip-path": "^1.0.0",
    "tailwindcss": "^3.3.2",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.0.4",
    "undici": "^7.28.0",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2",
    "zod": "^3.21.4"
  },
