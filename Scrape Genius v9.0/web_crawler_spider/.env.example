# ScrapeGenius frontend (Next.js + Prisma) config template.
# Copy to .env and fill in real values — this app is self-contained (auth,
# API keys, usage limits, dashboard stats, saved records, purchase codes all
# live in this database via Prisma) and does not depend on backend/.

# MySQL — Laragon default shown; use your production connection string in prod
DATABASE_URL="mysql://root:root@localhost:3306/google-map-scraper-pro"

# Auth — generate a real secret, e.g.: openssl rand -hex 48
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Daily usage limits (per API key)
DEFAULT_DAILY_LIMIT=100

# Port next start / next dev listen on (optional, defaults to 3000)
PORT=3000

# Express scraping microservice (backend/) — Facebook/LinkedIn/Twitter/Haraj/
# classified/Google Maps job engine lives there. This app proxies to it.
SCRAPER_BACKEND_URL=http://localhost:4000

# Internal service-to-service bridge — server-side only, NEVER exposed to the
# browser. MUST match backend/.env's INTERNAL_API_SECRET exactly.
INTERNAL_API_SECRET=replace-with-a-long-random-string
