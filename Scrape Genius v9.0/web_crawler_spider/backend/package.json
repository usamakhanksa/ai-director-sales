{
  "name": "scrapegenius-backend",
  "version": "1.0.0",
  "private": true,
  "description": "MySQL-backed Express API for ScrapeGenius (auth, Google search key/usage management, maps placeholder, admin)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:ensure": "node scripts/ensure-database.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "https-proxy-agent": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "ghost-cursor": "^1.4.2",
    "google-auth-library": "^9.14.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer": "^22.0.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xml2js": "^0.6.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}