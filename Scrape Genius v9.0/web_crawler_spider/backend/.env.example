# ScrapeGenius Express+Knex backend config template — a separate, standalone
# system from the Next.js frontend (which has its own Prisma-backed auth/
# API-key/usage/dashboard implementation and doesn't call this server).

# Server
PORT=4000
NODE_ENV=development

# MySQL — uses its own database, separate from the frontend's Prisma DB,
# since the two systems' users/api_keys/usage_logs schemas are incompatible.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=scrapegenius_backend

# Auth — generate a real secret, e.g.: openssl rand -hex 48
# Keep this distinct from the frontend's JWT_SECRET; tokens are not interchangeable.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Google Sign-in (signuploginwithgoogle)
GOOGLE_OAUTH_CLIENT_ID=

# Google Custom Search fallback key/engine, used only if api_keys table has no active rows
GOOGLE_API_FALLBACK_KEY=
GOOGLE_API_FALLBACK_CX=

# Daily usage limits (kept identical to original external_usage.json logic)
GOOGLE_SEARCH_DAILY_TOTAL_LIMIT=100
GOOGLE_SEARCH_DAILY_PER_KEY_LIMIT=100

# CORS - the Next.js frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# Internal service-to-service bridge — generate with: openssl rand -hex 48
# MUST match the frontend's INTERNAL_API_SECRET exactly. Never expose to browser code.
INTERNAL_API_SECRET=replace-with-a-long-random-string

# Playwright / Browser Engine (facebookScraper, linkedinScraper, googleMapsScraper, twitterScraper, harajScraper)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_CONCURRENCY=3

# Optional: one proxy per line (host:port or user:pass@host:port), read by antiRobotService
PROXY_LIST_FILE=proxies.txt

# Anti-Robot random delay bounds (ms) between simulated actions
RANDOM_DELAY_MIN_MS=1500
RANDOM_DELAY_MAX_MS=4500

# Export files are written under this directory, organized exports/{jobId}/{format}
EXPORT_DIR=./exports
